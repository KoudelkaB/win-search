<Window x:Class="search.DrivesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Indexed drives"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="12" MinWidth="380">
        <TextBlock TextWrapping="Wrap" MaxWidth="380"
                   Text="Choose which drives are indexed and searched. Unchecked drives are neither scanned nor watched. Drives without an explicit choice follow the default: NTFS drives are indexed, other file systems (network mounts, FAT sticks) are not - they cannot use the fast MFT read and their file-by-file walk can dominate the whole load."/>
        <ItemsControl x:Name="drivesList" Margin="0,10,0,0">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <CheckBox IsChecked="{Binding IsChecked}" Margin="0,3,0,0" VerticalContentAlignment="Center">
                        <TextBlock><Run FontWeight="SemiBold" Text="{Binding Root, Mode=OneWay}"/><Run Text="  "/><Run Text="{Binding Details, Mode=OneWay}"/></TextBlock>
                    </CheckBox>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <WrapPanel HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" MinWidth="80" Margin="3" IsDefault="True" Click="Ok_Click"/>
            <Button Content="Cancel" MinWidth="70" Margin="3" IsCancel="True"/>
        </WrapPanel>
    </StackPanel>
</Window>
