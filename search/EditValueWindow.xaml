<Window x:Class="search.EditValueWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:search"
        mc:Ignorable="d"
        MinHeight="80" MaxHeight="80" MinWidth="200" MaxWidth="300"
        Loaded="Window_Loaded">
    <Grid>
        <DockPanel LastChildFill="True">
            <DockPanel DockPanel.Dock="Bottom" LastChildFill="False">
                <Button DockPanel.Dock="Left" Content="Cancel" Width="60" IsCancel="True"/>
                <Button DockPanel.Dock="Right" Content="OK" Width="60" IsDefault="True" Click="Button_Click"/>
            </DockPanel>
            <TextBox Name="Value" DockPanel.Dock="Top"></TextBox>
        </DockPanel>
    </Grid>
</Window>
