<Window x:Class="search.FileCollisionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Destination already exists"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="12" MinWidth="420">
        <TextBlock Text="An item already exists at:"/>
        <TextBlock x:Name="Destination" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,4,0,10"/>
        <CheckBox x:Name="ApplyToAll" Content="Apply this choice to all remaining conflicts" Margin="0,0,0,10"/>
        <WrapPanel HorizontalAlignment="Right">
            <Button Content="Overwrite" MinWidth="80" Margin="3" Click="Overwrite_Click"/>
            <Button Content="Skip" MinWidth="70" Margin="3" Click="Skip_Click"/>
            <Button Content="Rename" MinWidth="70" Margin="3" Click="Rename_Click"/>
            <Button Content="Cancel" MinWidth="70" Margin="3" IsCancel="True" Click="Cancel_Click"/>
        </WrapPanel>
    </StackPanel>
</Window>
