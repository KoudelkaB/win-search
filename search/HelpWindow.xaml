<Window x:Class="search.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:search"
        Title="{local:Loc Key=Help}" Width="820" Height="700"
        MinWidth="500" MinHeight="400" WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <Button DockPanel.Dock="Bottom" Content="{local:Loc Key=Close}" IsCancel="True"
                HorizontalAlignment="Right" MinWidth="90" Margin="0,12,0,0"/>
        <FlowDocumentScrollViewer x:Name="viewer" IsToolBarVisible="True" VerticalScrollBarVisibility="Auto"/>
    </DockPanel>
</Window>
