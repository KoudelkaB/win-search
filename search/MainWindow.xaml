<Window x:Class="search.MainWindow"
        x:Name="Root"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:search"
        mc:Ignorable="d"
        Title="File Search Manager" Height="450" Width="800"
        Loaded="Window_Loaded" PreviewKeyDown="Window_KeyDown" PreviewKeyUp="Window_KeyUp">
    <Window.Resources>
        <local:Bool2VisibilityConverter x:Key="Bool2VisibilityConverter" />
        <local:IsDirectoryBooleanConverter x:Key="IsDirectoryBooleanConverter" />
        <local:IsFoundBooleanConverter x:Key="IsFoundBooleanConverter" />
        <local:ActiveFilterBrushConverter x:Key="ActiveFilterBrushConverter" />
        <!-- Green dot when idle, spinning blue dashed circle while running (bind the flag to Tag) -->
        <Style x:Key="BusyIndicator" TargetType="Ellipse">
            <Setter Property="Width" Value="11"/>
            <Setter Property="Height" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Fill" Value="LimeGreen"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <RotateTransform Angle="0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="Fill" Value="Transparent"/>
                    <Setter Property="Stroke" Value="DodgerBlue"/>
                    <Setter Property="StrokeThickness" Value="2.5"/>
                    <Setter Property="StrokeDashArray" Value="2 1.2"/>
                    <DataTrigger.EnterActions>
                        <BeginStoryboard x:Name="spin">
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(Ellipse.RenderTransform).(RotateTransform.Angle)"
                                                 From="0" To="360" Duration="0:0:1" RepeatBehavior="Forever"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="spin"/>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Bottom">
            <Border x:Name="TargetBar" BorderBrush="LightGray" BorderThickness="0,1,0,1" Padding="5,4" Background="#FFF8F8F8"
                    AllowDrop="True" PreviewDragOver="TargetBar_PreviewDragOver" DragOver="TargetBar_DragOver">
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="{local:Loc Key=ClearTargets}" Click="ClearTargets_Click"/>
                    </ContextMenu>
                </Border.ContextMenu>
                <StackPanel>
                    <Grid x:Name="BasketDropOverlay" Visibility="Collapsed" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" x:Name="BasketAddZone" AllowDrop="True" MinHeight="34"
                                Background="#FFE8F2FF" BorderBrush="#FF6A9BCB" BorderThickness="1"
                                CornerRadius="3" Margin="0,0,2,0"
                                DragOver="BasketAddZone_DragOver" DragLeave="BasketZone_DragLeave" Drop="BasketAddZone_Drop">
                            <TextBlock Text="{local:Loc Key=AddTarget}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="1" x:Name="BasketUseZone" AllowDrop="True" MinHeight="34"
                                Background="#FFEAF7EA" BorderBrush="#FF5B9B5B" BorderThickness="1"
                                CornerRadius="3" Margin="2,0,0,0"
                                DragOver="BasketUseZone_DragOver" DragLeave="BasketZone_DragLeave" Drop="BasketUseZone_Drop">
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"><Run Text="{local:Loc Key=SendAll}"/><Run Text=" ("/><Run Text="{Binding BasketTargets.Count, ElementName=Root, Mode=OneWay}"/><Run Text=")"/></TextBlock>
                        </Border>
                    </Grid>
                    <DockPanel LastChildFill="True">
                        <TextBlock DockPanel.Dock="Left" Text="{local:Loc Key=Targets}" FontWeight="DemiBold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="{local:Loc Key=AddName}" ToolTip="Add the selected Name-column items as targets (Alt+N)"
                                    Click="AddNameTargets_Click" Padding="5,1" Margin="6,0,0,0"/>
                            <Button Content="{local:Loc Key=AddFolder}" ToolTip="Add the selected items' parent folders as targets (Alt+F)"
                                    Click="AddFolderTargets_Click" Padding="5,1" Margin="3,0,0,0"/>
                            <Button Click="PasteToBasket_Click" Padding="5,1" Margin="9,0,0,0"
                                    ToolTip="Send clipboard files to every target (Alt+V)"
                                    ToolTipService.ShowOnDisabled="True">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BasketTargets.Count, ElementName=Root}" Value="0">
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <AccessText Text="{Binding BasketTargets.Count, ElementName=Root, Mode=OneWay, StringFormat='Send clipboard to all ({0})…'}"/>
                            </Button>
                        </StackPanel>
                        <Border MinHeight="28" Padding="3,1" Margin="0,0,0,0" BorderBrush="#FF9A9A9A" BorderThickness="1" CornerRadius="3">
                            <Border x:Name="BasketItemsZone" AllowDrop="True" Background="Transparent"
                                    ToolTip="Drop on empty space to add targets"
                                    DragOver="BasketAddZone_DragOver" DragLeave="BasketZone_DragLeave" Drop="BasketAddZone_Drop">
                                <ItemsControl ItemsSource="{Binding BasketTargets, ElementName=Root}" VerticalAlignment="Center">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Tag="{Binding}" AllowDrop="True" Margin="0,0,4,0" Padding="5,2"
                                                    ToolTip="{Binding Path}" DragOver="BasketTarget_DragOver"
                                                    DragLeave="BasketZone_DragLeave" Drop="BasketTarget_Drop"
                                                    MouseDoubleClick="Target_MouseDoubleClick">
                                                <Button.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="{local:Loc Key=FilterTarget}" Click="TargetFilter_Click"/>
                                                        <MenuItem Header="{local:Loc Key=OpenTarget}" Click="TargetOpen_Click"/>
                                                        <Separator/>
                                                        <MenuItem Header="{local:Loc Key=RemoveTarget}" Click="TargetRemove_Click"/>
                                                        <MenuItem Header="{local:Loc Key=ClearAllTargets}" Click="ClearTargets_Click"/>
                                                    </ContextMenu>
                                                </Button.ContextMenu>
                                                <TextBlock><Run Text="{Binding Icon, Mode=OneWay}"/><Run Text=" "/><Run Text="{Binding Name, Mode=OneWay}"/></TextBlock>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </Border>
                    </DockPanel>
                </StackPanel>
            </Border>
            <StackPanel Orientation="Horizontal">
                <Ellipse Style="{StaticResource BusyIndicator}" Tag="{Binding Loading}" Margin="5,0,0,0"/>
                <Label Content="{Binding CountsInfo}" Padding="5,0,5,0" />
                <Label Content="{Binding LoadStatus}" ToolTip="{Binding LoadStatusTooltip}" Padding="0,0,5,0" />
                <Button Content="{local:Loc Key=Drives}" Click="Drives_Click" Padding="6,0" Margin="0,0,5,0"
                        ToolTip="Choose which drives are indexed (NTFS drives by default)"/>
                <TextBlock Text="|" VerticalAlignment="Center" Margin="0,0,5,0" />
                <Label Content="{Binding Status}" Padding="0" />
            </StackPanel>
        </StackPanel>
        <StackPanel Name="help" DockPanel.Dock="Right" Orientation="Vertical" Margin="5">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right" Content="🌐" Click="Language_Click" Padding="2,0" MinWidth="24" Foreground="DodgerBlue"
                        ToolTip="{local:Loc Key=Language}" AutomationProperties.Name="{local:Loc Key=Language}"/>
                <TextBlock FontWeight="DemiBold" Text="{local:Loc Key=Hints}" VerticalAlignment="Center"/>
            </DockPanel>
            <TextBlock x:Name="filterTextBoxCmd">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding ElementName=filterTextBox, Path=IsKeyboardFocusWithin}" Value="True"/>
                                    <Condition Binding="{Binding ElementName=globalCmd, Path=IsReceivingCommandKeys}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <TextBlock x:Name="findCmd">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding ElementName=findTextBox, Path=IsKeyboardFocusWithin}" Value="True"/>
                                    <Condition Binding="{Binding ElementName=globalCmd, Path=IsReceivingCommandKeys}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <local:KeysCommander x:Name="filesViewCmd" Visibility=
                                 "{Binding ElementName=filesView, Path=IsKeyboardFocusWithin, Converter={StaticResource Bool2VisibilityConverter}}" />
            <local:KeysCommander x:Name="globalCmd" Margin="0,8,0,0">
                <local:KeysCommander.Style>
                    <Style TargetType="local:KeysCommander">
                        <Style.Triggers>
                            <!-- The focused result list shows its own commander incl. the ALT tree -->
                            <DataTrigger Binding="{Binding ElementName=filesView, Path=IsKeyboardFocusWithin}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </local:KeysCommander.Style>
            </local:KeysCommander>
        </StackPanel>
        <Grid DockPanel.Dock="Top" Margin="5,5,5,2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- Filter Row -->
            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,10,1">
                <Ellipse Style="{StaticResource BusyIndicator}" Tag="{Binding Filtering}"/>
                <Label Content="{local:Loc Key=Filter}" VerticalAlignment="Center"/>
            </StackPanel>
            <local:AutoCompleteTextBox Grid.Row="0" Grid.Column="1" x:Name="filterTextBox"
                                       TextChanged="TextBox_TextChanged" PreviewKeyDown="filterTextBox_PreviewKeyDown" 
                                       Margin="0,0,0,1"/>
            <Button Grid.Row="0" Grid.Column="2" Content="{local:Loc Key=Pin}" Click="PinFilter_Click"
                    Margin="3,0,0,1" Padding="6,0" ToolTip="Save this filter under a name (Alt+P)"/>
            <StackPanel Grid.Row="0" Grid.Column="3" Orientation="Horizontal">
                <Button Content="{local:Loc Key=Import}" Click="ImportWorkspace_Click" Margin="3,0,0,1" Padding="5,0"
                        ToolTip="Replace pinned filters and targets from a settings file (Alt+I)"/>
                <Button Content="{local:Loc Key=Export}" Click="ExportWorkspace_Click" Margin="3,0,0,1" Padding="5,0"
                        ToolTip="Save pinned filters and targets to a settings file (Alt+E)"/>
            </StackPanel>

            <ItemsControl Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                          ItemsSource="{Binding PinnedFilters, ElementName=Root}" Margin="0,1,0,2">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,4,0">
                            <Button Content="{Binding Name}" Tag="{Binding}" Click="PinnedFilter_Click"
                                    ToolTip="{Binding Filter}" Padding="7,1">
                                <Button.Background>
                                    <MultiBinding Converter="{StaticResource ActiveFilterBrushConverter}">
                                        <Binding Path="Filter"/>
                                        <Binding ElementName="filterTextBox" Path="Text"/>
                                    </MultiBinding>
                                </Button.Background>
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="{local:Loc Key=UpdateFilter}" Click="PinnedFilterUpdate_Click"/>
                                        <MenuItem Header="{local:Loc Key=Rename}" Click="PinnedFilterRename_Click"/>
                                        <Separator/>
                                        <MenuItem Header="{local:Loc Key=Unpin}" Click="PinnedFilterRemove_Click"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     MinWidth="120" Padding="5,1"
                                     TextChanged="PinnedFilterName_TextChanged"
                                     PreviewKeyDown="PinnedFilterName_KeyDown"
                                     LostKeyboardFocus="PinnedFilterName_LostKeyboardFocus"
                                     IsVisibleChanged="PinnedFilterName_IsVisibleChanged">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            
            <!-- Search Row -->
            <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,0,10,0">
                <Ellipse Style="{StaticResource BusyIndicator}" Tag="{Binding Searching}"/>
                <Label Content="{local:Loc Key=Search}" VerticalAlignment="Center"/>
            </StackPanel>
            <local:AutoCompleteTextBox Grid.Row="2" Grid.Column="1" x:Name="findTextBox"
                                       PreviewKeyDown="findTextBox_PreviewKeyDown" 
                                       Margin="0"/>
            <ComboBox Grid.Row="2" Grid.Column="2" x:Name="encodingComboBox" SelectedIndex="0"
                      VerticalAlignment="Stretch" Margin="3,0,0,0" MinWidth="60"
                      Height="{Binding ActualHeight, ElementName=findTextBox}"
                      SelectionChanged="EncodingComboBox_SelectionChanged">
                <ComboBoxItem Content="UTF-8"/>
                <ComboBoxItem Content="UTF-16"/>
                <ComboBoxItem Content="HEX"/>
            </ComboBox>
            <CheckBox Grid.Row="2" Grid.Column="3" x:Name="caseInsensitive" Content="{local:Loc Key=CaseInsensitive}"
                      VerticalAlignment="Center" Margin="3,0,0,0"/>
        </Grid>
        <Border x:Name="inlineActionBar" DockPanel.Dock="Top" Visibility="Collapsed"
                Background="#FFFFF7D6" BorderBrush="#FFD8B24A" BorderThickness="0,1"
                Padding="7,4">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right" Content="{local:Loc Key=Cancel}" Click="InlineActionCancel_Click" Margin="4,0,0,0" Padding="8,1"/>
                <Button DockPanel.Dock="Right" Content="{local:Loc Key=Create}" Click="InlineActionAccept_Click" Margin="4,0,0,0" Padding="8,1"/>
                <TextBlock x:Name="inlineActionLabel" DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,7,0"/>
                <TextBox x:Name="inlineActionTextBox" PreviewKeyDown="InlineActionTextBox_KeyDown"/>
            </DockPanel>
        </Border>
        <ListView x:Name="filesView" ItemsSource="{Binding Items}" GridViewColumnHeader.Click="ListViewColumnHeader_Click" SelectionMode="Extended"
                  PreviewKeyDown="ListView_KeyDown" PreviewKeyUp="ListView_PreviewKeyUp"
                  PreviewMouseMove="FilesView_PreviewMouseMove"
                  PreviewMouseLeftButtonUp="FilesView_PreviewMouseLeftButtonUp"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  VirtualizingPanel.CacheLength="1,1" VirtualizingPanel.CacheLengthUnit="Page">
            <ListView.ContextMenu>
                <ContextMenu Opened="FilesContextMenu_Opened" Closed="FilesContextMenu_Closed">
                    <MenuItem Header="{local:Loc Key=Open}" InputGestureText="Enter" Click="ContextOpen_Click"/>
                    <MenuItem Header="{local:Loc Key=OpenWith}" Tag="OpenWith"/>
                    <MenuItem Header="{local:Loc Key=OpenFolder}" Click="ContextOpenFolder_Click"/>
                    <Separator/>
                    <MenuItem Header="{local:Loc Key=Copy}" InputGestureText="Ctrl+C" Click="ContextCopy_Click"/>
                    <MenuItem Header="{local:Loc Key=Cut}" InputGestureText="Ctrl+X" Click="ContextCut_Click"/>
                    <MenuItem Header="{local:Loc Key=Paste}" InputGestureText="Ctrl+V" Click="ContextPaste_Click"/>
                    <MenuItem Header="{local:Loc Key=AddTarget}" Tag="AddTarget" Click="ContextAddTarget_Click"/>
                    <Separator/>
                    <MenuItem Header="{local:Loc Key=CopyPath}" Click="ContextCopyPath_Click"/>
                    <MenuItem Header="{local:Loc Key=Rename}" InputGestureText="F2" Click="ContextRename_Click"/>
                    <Separator/>
                    <MenuItem Header="{local:Loc Key=Zip}" InputGestureText="Z" Tag="Zip" Click="ContextZip_Click"/>
                    <MenuItem Header="{local:Loc Key=Create7z}" Tag="Zip7z" Click="ContextZip7z_Click"/>
                    <MenuItem Header="{local:Loc Key=Unzip}" InputGestureText="U" Tag="Unzip" Click="ContextUnzip_Click"/>
                    <Separator/>
                    <MenuItem Header="{local:Loc Key=Recycle}" InputGestureText="Delete" Click="ContextDelete_Click"/>
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.ItemContainerStyle>
                <Style TargetType="{x:Type ListViewItem}">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <EventSetter Event="PreviewMouseDoubleClick" Handler="ListViewItem_MouseDoubleClick" />
                    <EventSetter Event="PreviewMouseRightButtonDown" Handler="ListViewItem_RightButtonDown" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Attributes, Converter={StaticResource IsDirectoryBooleanConverter}}" Value="True">
                            <Setter Property="Foreground" Value="Blue"/>
                        </DataTrigger>
                        <DataTrigger Value="True">
                            <DataTrigger.Binding>
                                <MultiBinding Converter="{StaticResource IsFoundBooleanConverter}">
                                    <Binding/>
                                    <Binding Path="DataContext" RelativeSource="{RelativeSource Mode=FindAncestor, AncestorType={x:Type ListView}}" />
                                </MultiBinding>
                            </DataTrigger.Binding>
                            <Setter Property="Foreground" Value="Green"/>
                        </DataTrigger>
                        <DataTrigger Value="False">
                            <DataTrigger.Binding>
                                <MultiBinding Converter="{StaticResource IsFoundBooleanConverter}">
                                    <Binding/>
                                    <Binding Path="DataContext" RelativeSource="{RelativeSource Mode=FindAncestor, AncestorType={x:Type ListView}}" />
                                </MultiBinding>
                            </DataTrigger.Binding>
                            <Setter Property="Foreground" Value="Red"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.View>
                <GridView AllowsColumnReorder="True">
                    <GridViewColumn Header="C" Width="20">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding Foreground, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListViewItem}}}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="{local:Loc Key=Name}" Width="Auto">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border Tag="Name" Background="Transparent" AllowDrop="True"
                                        PreviewMouseLeftButtonDown="Name_PreviewMouseDoubleClick"
                                        DragOver="FileCell_DragOver" DragLeave="FileCell_DragLeave" Drop="FileCell_Drop">
                                    <Grid>
                                        <TextBlock x:Name="NameDisplay" Text="{Binding Name}"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListViewItem}}}" />
                                        <TextBox x:Name="InlineNameEditor" Visibility="Collapsed" Tag="{Binding}"
                                                 PreviewKeyDown="InlineNameEditor_KeyDown"
                                                 LostKeyboardFocus="InlineNameEditor_LostKeyboardFocus"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="{local:Loc Key=Size}" Width="Auto">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <!-- ##0 so a real zero-byte file shows "0" - the all-# format rendered it
                                     as an empty cell, indistinguishable from a missing value -->
                                <TextBlock Text="{Binding Size, StringFormat={}{0:### ### ### ##0}}" TextAlignment="Right" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="{local:Loc Key=Changed}" DisplayMemberBinding="{Binding LastChangeTime, StringFormat={}{0:g}}" Width="Auto"/>
                    <GridViewColumn Header="{local:Loc Key=Folder}" Width="Auto">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border Tag="Folder" Background="Transparent" AllowDrop="True"
                                        PreviewMouseLeftButtonDown="Folder_PreviewMouseDoubleClick"
                                        DragOver="FileCell_DragOver" DragLeave="FileCell_DragLeave" Drop="FileCell_Drop">
                                    <TextBlock Text="{Binding Folder}"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListViewItem}}}" />
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</Window>
