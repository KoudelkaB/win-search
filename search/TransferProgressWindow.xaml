<Window x:Class="search.TransferProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="File operation"
        Width="560"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Closing="Window_Closing">
    <StackPanel Margin="12">
        <TextBlock x:Name="Operation" FontWeight="SemiBold"/>
        <TextBlock x:Name="CurrentItem" TextWrapping="Wrap" Margin="0,6"/>
        <ProgressBar x:Name="Progress"
                     Height="18"
                     Minimum="0"
                     Maximum="100"
                     Foreground="#FF16A34A"
                     Margin="0,4,0,4"/>
        <Grid Margin="0,0,0,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="ProgressText" Text="Starting…"/>
            <TextBlock x:Name="BytesText" Grid.Column="2" Text="0 B of 0 B"/>
        </Grid>
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="ElapsedText" Text="Elapsed: 0:00"/>
            <TextBlock x:Name="RemainingText" Grid.Column="1" Text="Remaining: estimating…"/>
        </Grid>
        <Button x:Name="CancelButton"
                Content="Cancel"
                Width="80"
                HorizontalAlignment="Right"
                ToolTipService.ShowOnDisabled="True"
                Click="Cancel_Click"/>
    </StackPanel>
</Window>
