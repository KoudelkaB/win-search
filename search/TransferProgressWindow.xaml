<Window x:Class="search.TransferProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="File operation"
        Width="480"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Closing="Window_Closing">
    <StackPanel Margin="12">
        <TextBlock x:Name="Operation" FontWeight="SemiBold"/>
        <TextBlock x:Name="CurrentItem" TextWrapping="Wrap" Margin="0,6"/>
        <ProgressBar x:Name="Progress" Height="18" Minimum="0" Margin="0,4,0,10"/>
        <Button x:Name="CancelButton" Content="Cancel" Width="80" HorizontalAlignment="Right" Click="Cancel_Click"/>
    </StackPanel>
</Window>
